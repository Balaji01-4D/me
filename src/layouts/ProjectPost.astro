---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import simpleIconsCollection from '@iconify-json/simple-icons/icons.json';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Prose from '../components/Prose.astro';
import { slugify, withBase } from '../utils/slugify';

const getIconName = (tech: string) => {
	const name = tech.toLowerCase().replace(/[.\s]+/g, '').replace('c++', 'cplusplus').replace('c#', 'csharp').replace(/^go$/, 'go');
	return (simpleIconsCollection.icons as Record<string, any>)[name] ? `simple-icons:${name}` : null;
};

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	Content?: any;
	tags?: string[];
	stack?: string[];
	github?: string;
	docs?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], stack = [], github, docs, Content } = Astro.props as Props;
---

<BaseLayout title={title} description={description} image={heroImage}>
	<div class="flex-1 flex flex-col py-12 md:py-16 lg:py-20 space-y-16">
	<article class="post-page max-w-4xl w-full mx-auto">
		<header class="section-heading">
			<p class="eyebrow">Project</p>
			<div class="flex flex-wrap items-center gap-x-4 gap-y-2">
				<h1>{title}</h1>
				<div class="flex items-center gap-3">
					{github && (
						<a href={github} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-ink transition-colors" title="GitHub Repository">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A4.8 4.8 0 0 0 9 18v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
						</a>
					)}
					{docs && (
						<a href={docs} target="_blank" rel="noopener noreferrer" class="text-muted hover:text-ink transition-colors" title="Documentation">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
						</a>
					)}
				</div>
			</div>
			<p class="post-meta">
				<FormattedDate date={pubDate} />
				{updatedDate && (
					<span>
						&middot; Updated <FormattedDate date={updatedDate} />
					</span>
				)}
			</p>
			{tags.length > 0 && (
				<ul class="mt-2 flex flex-wrap gap-2 text-sm text-muted">
					{tags.map((tag) => (
						<li class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1">
							<a class="hover:text-ink" href={withBase(`/tags/${slugify(tag)}/`)}>{tag}</a>
						</li>
					))}
				</ul>
			)}
		</header>

		{heroImage && (
			<figure class="post-hero-image mb-12">
				<Image width={1020} height={510} src={heroImage} alt="" class="rounded-2xl" />
			</figure>
		)}

		<div class="space-y-12">
			{stack.length > 0 && (
				<div class="flex flex-col gap-3 pt-4">
					<h3 class="text-xs font-semibold text-muted uppercase tracking-widest">Tech Specs</h3>
					<div class="flex flex-wrap gap-x-6 gap-y-3">
						{stack.map((tech) => {
							const iconName = getIconName(tech);
							return (
								<span class="inline-flex items-center gap-2 text-sm font-medium text-ink/80">
									{iconName && <Icon name={iconName} class="w-4 h-4 opacity-75" />}
									{tech}
								</span>
							);
						})}
					</div>
				</div>
			)}

			<section class="post-article">
				<Prose>
					{Content ? <Content /> : <slot />}
				</Prose>
			</section>
		</div>
	</article>
	</div>
</BaseLayout>
