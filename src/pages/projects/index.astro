---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

import { getSite } from '../../utils/consts';
import { withBase } from '../../utils/slugify';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const site = await getSite();
---

<PageLayout title={`Projects · ${site.title}`} description="Explore case studies and recent builds.">
	<section class="content-shell py-12 space-y-10">
		<header class="space-y-2">
			<p class="text-sm uppercase tracking-[0.35em] text-muted">Projects</p>
			<h1 class="text-4xl font-semibold text-ink">Product stories and recent experiences</h1>
			<p class="text-muted max-w-3xl">
				Sharing results, learnings, and design structures that power creative and technical teams.
			</p>
		</header>
		{projects.length === 0 ? (
			<p class="text-muted">No projects published yet.</p>
		) : (
			<div class="space-y-6">
				{projects.map((project) => (
					<a
						class="group block w-full rounded-[28px] border border-border bg-[color:var(--color-surface)] p-6 md:p-10 transition duration-300 hover:bg-border/30 hover:-translate-y-1 shadow-none"
						href={withBase(`/projects/${project.id}/`)}
					>
						<div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
							<h3 class="text-2xl font-semibold tracking-tight text-ink group-hover:text-ink">{project.data.title}</h3>
							<time class="text-xs uppercase tracking-widest text-muted whitespace-nowrap" datetime={project.data.pubDate.toISOString()}>
								{project.data.pubDate.toLocaleDateString('en-US', {
									month: 'long',
									year: 'numeric',
								})}
							</time>
						</div>
						<p class="mt-4 text-[1.10rem] leading-relaxed text-muted/90 max-w-3xl">{project.data.description}</p>
					</a>
				))}
			</div>
		)}
	</section>
</PageLayout>
