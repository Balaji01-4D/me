---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import BentoGrid from '../components/home/BentoGrid.astro';
import { getSite } from '../utils/consts';
const site = await getSite();
---

<PageLayout
	title={site.title}
>
	<Hero
		eyebrow="Hi, I'm Balaji — a Systems Developer"
		title="Engineering robust backend systems."
		description="Highly ambitious pre-final year engineering student focused on low-level systems and backend development."
		actions={[
			{ label: 'View Projects', href: '/projects', variant: 'primary' },
			{ label: 'Contact', href: '/contact', variant: 'ghost' },
		]}
	/>

	<BentoGrid />

	

</PageLayout>
