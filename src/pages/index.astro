---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import PostList from '../components/PostList.astro';
import Numbers from '../components/Numbers.astro';
import Values from '../components/Values.astro';
import { getSite } from '../utils/consts';
const site = await getSite();
---

<PageLayout
	title={site.title}
>
	<Hero
		eyebrow="Systems & Backend Developer"
		title="Hi, I'm Balaji."
		description="I'm a highly ambitious pre-final year Engineering Student focused on low-level systems, backend development, and a dedicated Arch Linux user."
		actions={[
			{ label: 'View Projects', href: '/projects' },
			{ label: 'Read Blog', href: '/blog' },
		]}
	/>

	<Numbers
		eyebrow="Experience"
		title="My Journey"
		copy="A dedication to software engineering and low-level development."
		stats={[
			{ label: 'Role', value: 'Student', description: 'Pre-final year engineering.' },
			{ label: 'Focus', value: 'Backend', description: 'Building scalable systems.' },
			{ label: 'Interest', value: 'Low-level', description: 'Exploring the depths of systems.' },
			{ label: 'OS', value: 'Arch', description: 'Btw, I use Arch Linux.' },
		]}
	/>

	<Values
		eyebrow="Personality"
		title="What drives me"
		copy="Traits that define my approach to technology and engineering."
		values={[
			{ title: 'Highly ambitious', description: 'Always eager to learn and tackle complex architectural challenges.' },
			{ title: 'Systematic approach', description: 'Focused on clean, robust, and maintainable backend systems.' },
			{ title: 'Curiosity driven', description: 'Constantly dissecting how low-level systems function under the hood.' },
			{ title: 'Dedicated', description: 'Persistent problem solver committed to delivering high-quality software.' },
		]}
	/>

	<PostList
		heading="Recent Posts"
		limit={3}
		viewAllHref="/blog"
	/>

</PageLayout>
