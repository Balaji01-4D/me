---
import PageLayout from '../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
import { getSite } from '../utils/consts';
import { getCollection } from 'astro:content';

const site = await getSite();
const socials = (await getCollection('socials')).map((entry) => entry.data);

const email = socials.find(s => s.id === 'email')?.href?.replace('mailto:', '') || 'hey@example.com';
const github = socials.find(s => s.id === 'github')?.href || '#';
const linkedin = socials.find(s => s.id === 'linkedin')?.href || '#';
---

<PageLayout title={`Contact | ${site.title}`}>
	<section class="max-w-4xl mx-auto px-4 w-full py-20 md:py-32 flex flex-col items-center justify-center min-h-[70vh]">
		<div class="text-center mb-16">
			<h1 class="text-4xl md:text-6xl font-bold tracking-tight text-ink mb-6">Let's build something.</h1>
			<p class="text-xl text-muted/90 max-w-2xl mx-auto">Available for discussions on systems architecture and backend roles.</p>
		</div>

		<div class="w-full max-w-2xl grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
			<!-- Primary Card: Email -->
			<div class="md:col-span-2 group rounded-[32px] bg-[color:var(--color-surface)] border border-border p-10 flex flex-col items-center justify-center hover:bg-border/30 transition-colors text-center relative overflow-hidden">
				<div class="w-16 h-16 rounded-full bg-ink/5 border border-border flex items-center justify-center mb-6 group-hover:scale-110 transition-transform">
					<Icon name="lucide:mail" class="w-8 h-8 text-ink" />
				</div>
				<h3 class="text-lg font-medium text-muted mb-2">Drop me a line</h3>
				<a href={`mailto:${email}`} class="text-2xl sm:text-3xl md:text-5xl font-bold tracking-tight text-ink hover:text-ink/80 transition-colors duration-300 break-all">{email}</a>
			</div>

			<!-- Secondary Card: GitHub -->
			<a href={github} target="_blank" rel="noopener noreferrer" class="group rounded-[32px] bg-[color:var(--color-surface)] border border-border p-8 flex flex-col items-center justify-center hover:bg-border/30 transition-colors">
				<div class="w-14 h-14 rounded-full bg-ink/5 border border-border flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
					<Icon name="lucide:github" class="w-6 h-6 text-ink" />
				</div>
				<h3 class="text-xl font-bold tracking-tight text-ink">GitHub</h3>
			</a>

			<!-- Secondary Card: LinkedIn -->
			<a href={linkedin} target="_blank" rel="noopener noreferrer" class="group rounded-[32px] bg-[color:var(--color-surface)] border border-border p-8 flex flex-col items-center justify-center hover:bg-border/30 transition-colors">
				<div class="w-14 h-14 rounded-full bg-ink/5 border border-border flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
					<Icon name="lucide:linkedin" class="w-6 h-6 text-ink" />
				</div>
				<h3 class="text-xl font-bold tracking-tight text-ink">LinkedIn</h3>
			</a>
		</div>
	</section>
</PageLayout>
