---
import { getCollection } from "astro:content";
import { withBase } from "../utils/slugify";
import FormattedDate from "./FormattedDate.astro";

interface RawPost {
  id?: string;
  data?: {
    title?: string;
    description?: string;
    heroImage?: any;
    pubDate?: Date | string;
  };
  title?: string;
  description?: string;
  heroImage?: any;
  pubDate?: Date | string;
  href?: string;
}

export interface Props {
  heading?: string;
  posts?: RawPost[];
  limit?: number;
  viewAllHref?: string;
  viewAllLabel?: string;
}

let {
  heading = "Blog",
  posts = [],
  limit = 3,
  viewAllHref = "/blog/",
  viewAllLabel = "View all articles ->",
} = Astro.props as Props;

function getPostData(item: RawPost) {
  return item && (item as any).data ? (item as any).data : item;
}

if (posts.length === 0) {
  posts = posts
    .concat(await getCollection("blog"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
}

const visiblePosts = typeof limit === "number" ? posts.slice(0, limit) : posts;

// High-contrast monochromatic Code / Geometric Patterns for thumbnails
const codeSnippets = [
  `func main() {\n  fmt.Println("Hello, World!")\n  go routine()\n}`,
  `def generate_primes():\n  primes = []\n  for num in range(2, 50):\n    if all(num % i != 0 for i in range(2, int(num**0.5) + 1)):\n      primes.append(num)\n  return primes`,
  `async function fetch() {\n  const res = await api.get();\n  return res.json();\n}`
];
---

<section class="py-12 md:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 space-y-4 md:space-y-0 text-left">
      <div class="space-y-2">
        <h2 class="text-3xl sm:text-4xl font-semibold leading-tight text-ink m-0">
          blog.
        </h2>
        <p class="text-muted m-0">Recent writing and updates</p>
      </div>
      <a href={withBase(viewAllHref)} class="text-sm font-medium text-ink hover:text-ink/80 transition-colors uppercase tracking-widest flex items-center gap-1">
        {viewAllLabel}
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        visiblePosts.map((post, i) => {
          const p = getPostData(post) || {};
          const id = (post as any).id;
          const href = id ? withBase(`/blog/${id}/`) : p.href ? withBase(p.href) : undefined;
          const rawDate = p.pubDate ?? null;
          const pubDate = rawDate ? (rawDate instanceof Date ? rawDate : new Date(rawDate)) : null;
          const snippet = codeSnippets[i % codeSnippets.length];

          return (
            <article class="group relative flex flex-col h-full bg-surface border border-border rounded-3xl overflow-hidden hover:border-ink/20 transition-colors duration-300">
              <a href={href} class="flex flex-col h-full no-underline focus:outline-none focus:ring-2 focus:ring-ink focus:ring-offset-2">
                <div class="h-48 w-full bg-ink text-surface flex items-center justify-center p-6 overflow-hidden relative font-mono text-xs leading-relaxed opacity-90 group-hover:opacity-100 transition-opacity">
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#444_1px,transparent_1px)] bg-[size:16px_16px] opacity-10 mix-blend-overlay"></div>
                  <pre class="w-full h-full relative z-10 break-all whitespace-pre-wrap flex items-center justify-center text-center text-surface/80 group-hover:text-surface transition-colors">{snippet}</pre>
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  {pubDate && (
                    <time class="text-xs uppercase tracking-widest text-muted mb-3 font-semibold">
                      <FormattedDate date={pubDate} />
                    </time>
                  )}
                  <h3 class="text-lg font-bold text-ink mb-2 group-hover:text-ink/80 transition-colors">
                    {p.title}
                  </h3>
                  {p.description && (
                    <p class="text-sm text-muted line-clamp-3">
                      {p.description}
                    </p>
                  )}
                </div>
              </a>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
