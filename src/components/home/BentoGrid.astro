---
import { Icon } from 'astro-icon/components';
---

<section class="max-w-6xl mx-auto px-4 w-full py-20 md:py-32">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-6 md:auto-rows-[320px]">
    
    <!-- Big Feature: Dev Env (Takes 2 cols on desktop) -->
    <div class="md:col-span-2 group relative overflow-hidden rounded-[32px] bg-[color:var(--color-surface)] border border-border shadow-none transition-all p-8 md:p-10 flex flex-col justify-end">
      <!-- Simulated Terminal Window -->
      <div class="absolute top-8 right-8 w-72 h-56 bg-[#11111b] rounded-xl border border-white/10 shadow-2xl overflow-hidden transform rotate-3 group-hover:rotate-0 transition-transform duration-500 hidden md:flex flex-col">
        <div class="h-8 w-full bg-[#1e1e2e] flex items-center px-4 gap-2 border-b border-white/5">
          <div class="w-3 h-3 rounded-full bg-[#f38ba8]"></div>
          <div class="w-3 h-3 rounded-full bg-[#f9e2af]"></div>
          <div class="w-3 h-3 rounded-full bg-[#a6e3a1]"></div>
        </div>
        <div class="p-5 font-mono text-xs text-[#cdd6f4] opacity-80 leading-loose">
          <span class="text-[#f9e2af]">balaji</span>@<span class="text-[#89b4fa]">archlinux</span> <span class="text-[#cba6f7]">~</span> $ nvim main.go<br/>
          loading language server...<br/>
          [gopls] initialized workspace<br/>
          <span class="text-[#cba6f7]">func</span> <span class="text-[#89b4fa]">main</span>() {"{"}<br/>
            &nbsp;&nbsp;fmt.Println(<span class="text-[#a6e3a1] bg-[#a6e3a1]/10 px-1 rounded">"Hello, World!"</span>)<br/>
          {"}"}
        </div>
      </div>
      <div class="relative z-10 w-full md:max-w-[60%]">
        <h3 class="text-2xl md:text-3xl font-bold tracking-tight text-ink mb-3">TUI Environment</h3>
        <p class="text-muted/90 text-lg leading-relaxed">Purely terminal-based workflows. Arch Linux, Wezterm, and Neovim heavily customized with Catppuccin.</p>
      </div>
    </div>

    <!-- Small Card: Focused Stack -->
    <div class="rounded-[32px] bg-[color:var(--color-surface)] border border-border p-8 md:p-10 flex flex-col items-start justify-between group hover:bg-border/30 transition-colors">
      <div class="w-14 h-14 rounded-full bg-ink/5 border border-border flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <Icon name="lucide:server" class="w-6 h-6 text-ink" />
      </div>
      <div>
        <h3 class="text-xl font-bold tracking-tight text-ink mb-2">Backend Focus</h3>
        <p class="text-muted text-[1.05rem] leading-relaxed">Building cleanly structured, scalable APIs and microservices.</p>
      </div>
    </div>

    <!-- Small Card: Low Level -->
    <div class="rounded-[32px] bg-[color:var(--color-surface)] border border-border p-8 md:p-10 flex flex-col items-start justify-between group hover:bg-border/30 transition-colors">
      <div class="w-14 h-14 rounded-full bg-ink/5 border border-border flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
        <Icon name="lucide:cpu" class="w-6 h-6 text-ink" />
      </div>
      <div>
        <h3 class="text-xl font-bold tracking-tight text-ink mb-2">Low-level</h3>
        <p class="text-muted text-[1.05rem] leading-relaxed">Dissecting how core systems function robustly under the hood.</p>
      </div>
    </div>

    <!-- Small Empty / Quote Card -->
    <div class="md:col-span-2 rounded-[32px] bg-ink text-surface p-8 md:p-10 flex flex-col justify-center relative overflow-hidden group">
      <Icon name="lucide:quote" class="w-10 h-10 text-surface/20 mb-6 absolute top-8 right-8" />
      <h3 class="text-2xl md:text-3xl font-bold tracking-tight mb-4">Curiosity Driven</h3>
      <p class="text-surface/80 text-lg md:text-xl leading-relaxed max-w-lg">I approach software engineering as a continuous loop of dissecting, understanding, and improving architectures.</p>
    </div>

  </div>
</section>
