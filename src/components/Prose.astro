---
const { class: className = '' } = Astro.props;
---

<article
	class={
		`prose max-w-none prose-headings:text-ink prose-p:text-muted prose-li:text-muted prose-strong:text-ink prose-a:text-ink prose-code:text-ink prose-blockquote:text-muted marker:text-ink ${className}`.trim()
	}
>
	<slot />
</article>
